NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
FONNTE_API_TOKEN=your-fonnte-token
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@bri.co.id
SMTP_PASS=your-smtp-password
SMTP_FROM=BRIMOS <noreply@bri.co.id>

# App base URL — required for server-side internal API calls (e.g. sendEmail)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron secret — protect /api/cron/escalation
CRON_SECRET=your-random-secret-here
